{
  "name": "todolist-desktop-pet",
  "version": "0.1.0",
  "description": "A Windows desktop pet TODOList app compatible with Codex pet packages.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && electron-vite build && electron-builder --win --dir --publish never"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "electron-updater": "^6.6.2",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.15"
  },
  "build": {
    "appId": "local.todolist.desktoppet",
    "productName": "TOList Desktop Pet",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "dir"
      ]
    }
  }
}
